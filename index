<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>金門旅遊團 - 個人基本資料確認系統</title>
    
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- 引入 React 與 ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- 引入 Babel (讓瀏覽器能看得懂 JSX 語法) -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        // ------------------------------------------------------------------
        // 將原本由外部載入的 Lucide Icons 改為輕量化的內建 SVG 元件
        // 這樣可以避免 CDN 載入失敗或版本不相容導致的錯誤
        // ------------------------------------------------------------------
        const IconBase = ({ children, className = "", ...props }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className} {...props}>
                {children}
            </svg>
        );

        const User = (props) => <IconBase {...props}><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></IconBase>;
        const Calendar = (props) => <IconBase {...props}><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></IconBase>;
        const CreditCard = (props) => <IconBase {...props}><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></IconBase>;
        const Plane = (props) => <IconBase {...props}><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6L3 8l6 3-4 4-2.5-.5L1 16l4 2 2 4 1.5-1.5-.5-2.5 4-4 3 6 1.2-.7c.4-.2.7-.6.6-1.1z"/></IconBase>;
        const CheckCircle = (props) => <IconBase {...props}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></IconBase>;
        const AlertCircle = (props) => <IconBase {...props}><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></IconBase>;
        const Save = (props) => <IconBase {...props}><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></IconBase>;
        const LogOut = (props) => <IconBase {...props}><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></IconBase>;
        const PlaneTakeoff = (props) => <IconBase {...props}><path d="M2 22h20"/><path d="M6.36 17.4 4 17l-2-4 1.1-.55a2 2 0 0 1 1.8 0l.17.1a2 2 0 0 0 1.8 0L8 12 5 6l2.7-1.4 6.8 5.4 5.3-2.6a2 2 0 0 1 2.8 1.1l.1.3a2 2 0 0 1-1 2.5l-14 7.6c-.5.3-1 .4-1.6.4z"/></IconBase>;
        const PlaneLanding = (props) => <IconBase {...props}><path d="M2 22h20"/><path d="m11.6 17 3.6-1.8 3.8-1.9a2 2 0 0 0 1.1-2.5v0a2 2 0 0 0-2.5-1.1L12.5 12l-6-5-2.7 1.4 3 6-5.8 2.9a2 2 0 0 0-1 2.5v0a2 2 0 0 0 2.5 1.1l2-.4 4.5-.9c1.6-.3 3.3-.6 5-.9z"/></IconBase>;
        const Clock = (props) => <IconBase {...props}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></IconBase>;
        const Ticket = (props) => <IconBase {...props}><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></IconBase>;
        const MapPin = (props) => <IconBase {...props}><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></IconBase>;
        const Cloud = (props) => <IconBase {...props}><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></IconBase>;
        const Camera = (props) => <IconBase {...props}><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></IconBase>;
        const Luggage = (props) => <IconBase {...props}><path d="M6 20h0a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h0"/><path d="M8 18V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"/><path d="M10 20v2"/><path d="M14 20v2"/></IconBase>;
        const Compass = (props) => <IconBase {...props}><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></IconBase>;

        // ------------------------------------------------------------------
        // 以下為系統主程式碼
        // ------------------------------------------------------------------
        const GAS_URL = "https://script.google.com/macros/s/AKfycbzzmm0XU7nWmfgN7wz0yXIhJ7yQWL_o2fjY5SYVGsFR8UAI-bX0zo_y0ht3_UjoyX9N/exec";

        function App() {
          const [isLoggedIn, setIsLoggedIn] = useState(false);
          const [loading, setLoading] = useState(false);
          const [error, setError] = useState('');
          const [successMsg, setSuccessMsg] = useState('');
          
          // 登入表單狀態
          const [loginForm, setLoginForm] = useState({
            birthMonth: '',
            birthDay: '',
            idSuffix: ''
          });

          // 使用者資料狀態
          const [userData, setUserData] = useState({
            name: '',
            birthday: '',
            idNumber: '',
            phone: '',
            email: '',
            rowIndex: -1 // 紀錄在試算表中的列數，方便回寫
          });

          // 新增：航班狀態確認
          const [flightStatus, setFlightStatus] = useState([]);

          // 唯讀資料狀態 (來自 團費&機票)
          const [extraData, setExtraData] = useState({
            paymentStatus: false,
            flightOut: { airline: '', date: '', time: '' },
            flightIn: { airline: '', date: '', time: '' }
          });

          // 處理登入輸入
          const handleLoginChange = (e) => {
            setLoginForm({ ...loginForm, [e.target.name]: e.target.value });
          };

          // 處理基本資料修改
          const handleDataChange = (e) => {
            setUserData({ ...userData, [e.target.name]: e.target.value });
          };

          // 處理航班確認複選題
          const handleFlightStatusChange = (e) => {
            const value = e.target.value;
            if (e.target.checked) {
              if (value === '班機正確無誤') {
                setFlightStatus(['班機正確無誤']);
              } else {
                setFlightStatus(prev => {
                  const newStatus = prev.filter(item => item !== '班機正確無誤');
                  return [...newStatus, value];
                });
              }
            } else {
              setFlightStatus(prev => prev.filter(item => item !== value));
            }
          };

          // 登入 API 呼叫
          const handleLoginSubmit = async (e) => {
            e.preventDefault();
            setLoading(true);
            setError('');

            if (!loginForm.birthMonth || !loginForm.birthDay || !loginForm.idSuffix || loginForm.idSuffix.length !== 5) {
              setError('請選擇生日並輸入身分證後五碼 (5位數)');
              setLoading(false);
              return;
            }

            const submitBirthday = `${loginForm.birthMonth}/${loginForm.birthDay}`;

            try {
              const response = await fetch(GAS_URL, {
                method: 'POST',
                headers: {
                  'Content-Type': 'text/plain;charset=utf-8',
                },
                body: JSON.stringify({
                  action: 'login',
                  birthday: submitBirthday,
                  idSuffix: loginForm.idSuffix
                })
              });

              const result = await response.json();

              if (result.success) {
                // 處理電話號碼 0 被試算表吃掉的問題
                let fetchedUser = result.user;
                let phoneStr = String(fetchedUser.phone || '').trim();
                if (/^[1-9]\d{7,8}$/.test(phoneStr)) {
                  phoneStr = '0' + phoneStr;
                }
                fetchedUser.phone = phoneStr;

                setUserData(fetchedUser);
                setExtraData(result.extra);
                setIsLoggedIn(true);
              } else {
                setError(result.message || '登入失敗，找不到符合的資料');
              }
            } catch (err) {
              console.error('API Error:', err);
              setError('系統連線發生錯誤，請確認 GAS 是否正確部署。');
            } finally {
              setLoading(false);
            }
          };

          // 送出修改並確認 API 呼叫
          const handleSubmitData = async () => {
            setLoading(true);
            setError('');
            setSuccessMsg('');

            try {
              const response = await fetch(GAS_URL, {
                method: 'POST',
                headers: {
                  'Content-Type': 'text/plain;charset=utf-8',
                },
                body: JSON.stringify({
                  action: 'update',
                  userData: {
                    ...userData,
                    flightStatus: flightStatus.join('、') // 將陣列轉為字串送出
                  }
                })
              });

              const result = await response.json();

              if (result.success) {
                setSuccessMsg('資料已成功確認並更新！');
                window.scrollTo(0, 0);
              } else {
                setError(result.message || '更新失敗，請稍後再試。');
              }
            } catch (err) {
              console.error('Update Error:', err);
              setError('系統連線發生錯誤，請稍後再試。');
            } finally {
              setLoading(false);
            }
          };

          const handleLogout = () => {
            setIsLoggedIn(false);
            setLoginForm({ birthMonth: '', birthDay: '', idSuffix: '' });
            setUserData({ name: '', birthday: '', idNumber: '', phone: '', email: '', rowIndex: -1 });
            setFlightStatus([]);
            setSuccessMsg('');
          };

          // 畫面：登入頁面
          if (!isLoggedIn) {
            return (
              <div 
                className="min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative bg-cover bg-center bg-no-repeat overflow-hidden"
                style={{ backgroundImage: "url('https://images.unsplash.com/photo-1577908906536-407481ba93b7?q=80&w=2070&auto=format&fit=crop')" }}
              >
                <style>
                  {`
                    @keyframes float {
                      0%, 100% { transform: translateY(0); }
                      50% { transform: translateY(-20px); }
                    }
                    .animate-float { animation: float 6s ease-in-out infinite; }
                    .delay-1 { animation-delay: 2s; }
                    .delay-2 { animation-delay: 4s; }
                  `}
                </style>

                <div className="absolute inset-0 bg-blue-900/50 backdrop-blur-[2px]"></div>

                <div className="absolute inset-0 pointer-events-none z-0 overflow-hidden">
                  <div className="absolute top-10 left-10 animate-float"><Cloud className="text-white/30 w-32 h-32" /></div>
                  <div className="absolute top-32 right-10 animate-float delay-1"><Cloud className="text-white/20 w-48 h-48" /></div>
                  <div className="absolute top-24 right-1/3 animate-float delay-2"><Plane className="text-white/40 w-24 h-24 transform rotate-45" /></div>
                  <div className="absolute bottom-20 left-1/4 animate-float delay-1"><Camera className="text-white/30 w-24 h-24 transform -rotate-12" /></div>
                  <div className="absolute bottom-32 right-20 animate-float"><Luggage className="text-white/30 w-24 h-24 transform rotate-12" /></div>
                  <div className="absolute top-1/3 left-5 animate-float delay-2"><Compass className="text-white/20 w-32 h-32 transform -rotate-12" /></div>
                </div>

                <div className="relative sm:mx-auto sm:w-full sm:max-w-md z-10 px-4 sm:px-0">
                  <div className="bg-white/95 backdrop-blur-md py-10 px-6 shadow-2xl rounded-2xl sm:px-10 border border-white/60">
                    
                    <div className="text-center mb-8">
                      <div className="inline-flex items-center justify-center p-3 bg-blue-50 rounded-full mb-4 shadow-inner">
                        <MapPin className="h-8 w-8 text-red-500 mr-1" />
                        <Plane className="h-8 w-8 text-blue-600" />
                      </div>
                      <h2 className="text-3xl font-extrabold text-gray-900 tracking-tight">
                        金門旅遊團
                      </h2>
                      <div className="mt-2 flex items-center justify-center space-x-2">
                        <span className="h-px w-8 bg-blue-300"></span>
                        <p className="text-md font-bold text-blue-600">
                          個人基本資料確認系統
                        </p>
                        <span className="h-px w-8 bg-blue-300"></span>
                      </div>
                    </div>

                    <form className="space-y-6" onSubmit={handleLoginSubmit}>
                      <div>
                        <label className="block text-sm font-bold text-gray-700 mb-1">
                          生日 (月/日)
                        </label>
                        <div className="mt-1 flex space-x-2">
                          <div className="relative flex-1 rounded-md shadow-sm">
                            <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                              <Calendar className="h-5 w-5 text-gray-400" />
                            </div>
                            <select
                              name="birthMonth"
                              value={loginForm.birthMonth}
                              onChange={handleLoginChange}
                              className="focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 sm:text-sm border-gray-300 rounded-lg p-2.5 border bg-white/80"
                              required
                            >
                              <option value="" disabled>月份</option>
                              {[...Array(12)].map((_, i) => {
                                const m = String(i + 1).padStart(2, '0');
                                return <option key={m} value={m}>{m} 月</option>;
                              })}
                            </select>
                          </div>
                          <div className="relative flex-1 rounded-md shadow-sm">
                            <select
                              name="birthDay"
                              value={loginForm.birthDay}
                              onChange={handleLoginChange}
                              className="focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-lg p-2.5 border bg-white/80"
                              required
                            >
                              <option value="" disabled>日期</option>
                              {[...Array(31)].map((_, i) => {
                                const d = String(i + 1).padStart(2, '0');
                                return <option key={d} value={d}>{d} 日</option>;
                              })}
                            </select>
                          </div>
                        </div>
                      </div>

                      <div>
                        <label htmlFor="idSuffix" className="block text-sm font-bold text-gray-700 mb-1">
                          身分證字號 (後五碼)
                        </label>
                        <div className="mt-1 relative rounded-md shadow-sm">
                          <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <User className="h-5 w-5 text-gray-400" />
                          </div>
                          <input
                            type="password"
                            name="idSuffix"
                            id="idSuffix"
                            maxLength="5"
                            className="focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 sm:text-sm border-gray-300 rounded-lg p-2.5 border bg-white/80 transition-colors"
                            placeholder="例如：12345"
                            value={loginForm.idSuffix}
                            onChange={handleLoginChange}
                            required
                          />
                        </div>
                      </div>

                      {error && (
                        <div className="rounded-lg bg-red-50 p-4 border border-red-100">
                          <div className="flex">
                            <div className="flex-shrink-0">
                              <AlertCircle className="h-5 w-5 text-red-500" />
                            </div>
                            <div className="ml-3">
                              <h3 className="text-sm font-bold text-red-800">{error}</h3>
                            </div>
                          </div>
                        </div>
                      )}

                      <div className="pt-2">
                        <button
                          type="submit"
                          disabled={loading}
                          className={`w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-md text-sm font-bold text-white ${
                            loading ? 'bg-blue-400 cursor-not-allowed' : 'bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 transform hover:-translate-y-0.5 transition-all'
                          } focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500`}
                        >
                          {loading ? '驗證登入中...' : '確認登入'}
                        </button>
                      </div>
                    </form>
                  </div>
                  
                  <div className="text-center mt-6">
                    <p className="text-white/80 text-sm font-medium drop-shadow-sm">
                      系統受加密保護，僅供本次旅行團員使用
                    </p>
                  </div>
                </div>
              </div>
            );
          }

          const parseFlight = (flight) => {
            if (!flight) return { airline: '未提供', date: '未提供', time: '未提供' };
            if (typeof flight === 'string') return { airline: flight, date: '未提供', time: '未提供' };
            return {
              airline: flight.airline || '未提供',
              date: flight.date || '未提供',
              time: flight.time || '未提供'
            };
          };

          const parsedFlightOut = parseFlight(extraData.flightOut);
          const parsedFlightIn = parseFlight(extraData.flightIn);

          // 畫面：資料確認頁面
          return (
            <div className="min-h-screen bg-gray-100 pb-12">
              <div 
                className="h-56 w-full bg-cover bg-center relative"
                style={{ backgroundImage: "url('https://images.unsplash.com/photo-1577908906536-407481ba93b7?q=80&w=2070&auto=format&fit=crop')" }}
              >
                <div className="absolute inset-0 bg-gradient-to-b from-blue-900/60 via-blue-900/40 to-gray-100"></div>
                <div className="absolute bottom-12 left-0 w-full px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
                  <div className="flex items-center space-x-2 mb-2">
                    <span className="px-2.5 py-1 rounded-md bg-red-500/90 text-white text-xs font-bold tracking-wider backdrop-blur-sm">金門行</span>
                    <span className="px-2.5 py-1 rounded-md bg-blue-600/90 text-white text-xs font-bold tracking-wider backdrop-blur-sm">資料確認</span>
                  </div>
                  <h1 className="text-3xl sm:text-4xl font-extrabold text-white drop-shadow-lg tracking-tight">
                    金門旅遊團
                  </h1>
                </div>
              </div>

              <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10 space-y-6">
                
                <div className="flex items-center justify-between bg-white p-5 rounded-xl shadow-lg border-l-4 border-blue-600">
                  <div>
                    <h2 className="text-xl sm:text-2xl font-bold text-gray-900">哈囉，{userData.name}</h2>
                    <p className="text-sm text-gray-500 mt-1">請確認下方的基本資料與行程資訊是否正確。</p>
                  </div>
                  <button 
                    onClick={handleLogout}
                    className="flex items-center px-4 py-2 text-sm font-bold text-gray-600 bg-gray-50 rounded-lg hover:bg-red-50 hover:text-red-600 transition-colors border border-gray-200"
                  >
                    <LogOut className="h-4 w-4 mr-2" />
                    登出
                  </button>
                </div>

                {successMsg && (
                  <div className="rounded-md bg-green-50 p-4 border border-green-200 shadow-sm">
                    <div className="flex">
                      <div className="flex-shrink-0">
                        <CheckCircle className="h-5 w-5 text-green-400" />
                      </div>
                      <div className="ml-3">
                        <h3 className="text-sm font-medium text-green-800">{successMsg}</h3>
                      </div>
                    </div>
                  </div>
                )}

                <div className="bg-white shadow overflow-hidden sm:rounded-lg">
                  <div className="px-4 py-5 sm:px-6 border-b border-gray-200">
                    <h3 className="text-lg leading-6 font-medium text-gray-900 flex items-center">
                      <User className="h-5 w-5 mr-2 text-blue-500" />
                      基本資料 (可修改)
                    </h3>
                    <p className="mt-1 max-w-2xl text-sm text-gray-500">
                      若資料有誤，您可以直接在此修改，修改後請記得點擊最下方的「確認資料無誤並送出」按鈕。
                    </p>
                  </div>
                  <div className="px-4 py-5 sm:p-6">
                    <div className="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
                      <div>
                        <label className="block text-sm font-medium text-gray-700">姓名</label>
                        <input
                          type="text"
                          name="name"
                          value={userData.name}
                          onChange={handleDataChange}
                          className="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md p-2 border"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-medium text-gray-700">出生日期 (保險用)</label>
                        <input
                          type="text"
                          name="birthday"
                          value={userData.birthday}
                          placeholder="例如：1990/05/12"
                          onChange={handleDataChange}
                          className="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md p-2 border"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-medium text-gray-700">身分證字號 (保險用)</label>
                        <input
                          type="text"
                          name="idNumber"
                          value={userData.idNumber}
                          onChange={handleDataChange}
                          className="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md p-2 border"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-medium text-gray-700">電話</label>
                        <input
                          type="tel"
                          name="phone"
                          value={userData.phone}
                          onChange={handleDataChange}
                          className="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md p-2 border"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-medium text-gray-700">電子信箱 Email</label>
                        <input
                          type="email"
                          name="email"
                          value={userData.email}
                          onChange={handleDataChange}
                          className="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md p-2 border"
                        />
                      </div>
                    </div>
                  </div>
                </div>

                <div className="bg-white shadow overflow-hidden sm:rounded-lg">
                  <div className="px-4 py-5 sm:px-6 border-b border-gray-200 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                    <h3 className="text-lg leading-6 font-medium text-gray-900 flex items-center">
                      <CreditCard className="h-5 w-5 mr-2 text-indigo-500" />
                      團費與航班資訊
                    </h3>
                    {extraData.paymentStatus ? (
                      <span className="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 border border-green-200">
                        <CheckCircle className="w-4 h-4 mr-1.5" /> 團費已繳清
                      </span>
                    ) : (
                      <span className="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800 border border-red-200">
                        <AlertCircle className="w-4 h-4 mr-1.5" /> 未繳費 / 確認中
                      </span>
                    )}
                  </div>
                  <div className="bg-gray-50 px-4 py-6 sm:p-6">
                    <div className="grid grid-cols-1 gap-6 sm:grid-cols-2">
                      <div className="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col transition hover:shadow-md">
                        <div className="flex items-center space-x-3 mb-4 border-b border-gray-100 pb-3">
                          <div className="bg-blue-50 p-2 rounded-full">
                            <PlaneTakeoff className="h-5 w-5 text-blue-600" />
                          </div>
                          <h4 className="text-base font-bold text-gray-800 tracking-wider">去程航班</h4>
                        </div>
                        {parsedFlightOut && (parsedFlightOut.date !== '未提供' || parsedFlightOut.airline !== '未提供') ? (
                          <ul className="space-y-3">
                            <li className="flex items-center text-gray-700">
                              <Ticket className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightOut.airline}</span>
                            </li>
                            <li className="flex items-center text-gray-700">
                              <Calendar className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightOut.date}</span>
                            </li>
                            <li className="flex items-center text-gray-700">
                              <Clock className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightOut.time}</span>
                            </li>
                          </ul>
                        ) : (
                          <p className="text-gray-500 text-sm py-2">尚無資訊或安排中</p>
                        )}
                      </div>

                      <div className="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col transition hover:shadow-md">
                        <div className="flex items-center space-x-3 mb-4 border-b border-gray-100 pb-3">
                          <div className="bg-indigo-50 p-2 rounded-full">
                            <PlaneLanding className="h-5 w-5 text-indigo-600" />
                          </div>
                          <h4 className="text-base font-bold text-gray-800 tracking-wider">回程航班</h4>
                        </div>
                        {parsedFlightIn && (parsedFlightIn.date !== '未提供' || parsedFlightIn.airline !== '未提供') ? (
                          <ul className="space-y-3">
                            <li className="flex items-center text-gray-700">
                              <Ticket className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightIn.airline}</span>
                            </li>
                            <li className="flex items-center text-gray-700">
                              <Calendar className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightIn.date}</span>
                            </li>
                            <li className="flex items-center text-gray-700">
                              <Clock className="w-5 h-5 mr-3 text-gray-400 flex-shrink-0" />
                              <span className="font-medium text-gray-900">{parsedFlightIn.time}</span>
                            </li>
                          </ul>
                        ) : (
                          <p className="text-gray-500 text-sm py-2">尚無資訊或安排中</p>
                        )}
                      </div>
                    </div>

                    <div className="mt-8 border-t border-gray-200 pt-6">
                      <h4 className="text-base font-medium text-gray-900 mb-4 flex items-center">
                        請確認您的航班資訊狀態：
                      </h4>
                      <div className="space-y-3">
                        <label className="flex items-center space-x-3 cursor-pointer p-2 hover:bg-gray-100 rounded-md transition-colors">
                          <input
                            type="checkbox"
                            value="班機正確無誤"
                            checked={flightStatus.includes('班機正確無誤')}
                            onChange={handleFlightStatusChange}
                            className="h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded"
                          />
                          <span className="text-gray-700 font-medium">1. 班機正確無誤</span>
                        </label>
                        <label className="flex items-center space-x-3 cursor-pointer p-2 hover:bg-gray-100 rounded-md transition-colors">
                          <input
                            type="checkbox"
                            value="去程班機有調整(送出後回報給柏睿)"
                            checked={flightStatus.includes('去程班機有調整(送出後回報給柏睿)')}
                            onChange={handleFlightStatusChange}
                            className="h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded"
                          />
                          <span className="text-gray-700 font-medium">2. 去程班機有調整 (送出後回報給柏睿)</span>
                        </label>
                        <label className="flex items-center space-x-3 cursor-pointer p-2 hover:bg-gray-100 rounded-md transition-colors">
                          <input
                            type="checkbox"
                            value="回程班機有調整(送出後回報給柏睿)"
                            checked={flightStatus.includes('回程班機有調整(送出後回報給柏睿)')}
                            onChange={handleFlightStatusChange}
                            className="h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded"
                          />
                          <span className="text-gray-700 font-medium">3. 回程班機有調整 (送出後回報給柏睿)</span>
                        </label>
                      </div>
                    </div>
                  </div>
                </div>

                <div className="pt-5 pb-8 flex justify-center">
                  <button
                    type="button"
                    onClick={handleSubmitData}
                    disabled={loading}
                    className={`inline-flex items-center px-8 py-4 border border-transparent text-lg font-medium rounded-md shadow-sm text-white ${
                      loading ? 'bg-green-400 cursor-not-allowed' : 'bg-green-600 hover:bg-green-700'
                    } focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors`}
                  >
                    {loading ? (
                      '處理中...'
                    ) : (
                      <>
                        <Save className="mr-2 h-6 w-6" />
                        確認資料無誤並送出
                      </>
                    )}
                  </button>
                </div>

              </div>
            </div>
          );
        }

        // 啟動 React 應用程式
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
